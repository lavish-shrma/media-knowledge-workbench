# Application metadata.
APP_NAME=AI Document and Multimedia Q&A
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database connection string for local development or Docker Compose.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME

# Local storage directory for uploaded files and derived artifacts.
UPLOADS_DIR=./uploads

# OpenAI settings used only if live LLM-backed summarization/chat is enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Whisper transcription model name used for local media processing.
WHISPER_MODEL=base

# Redis endpoint for caching and rate limiting.
REDIS_URL=redis://localhost:6379/0

# JWT signing secret for access and refresh tokens.
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Token lifetimes in minutes/days.
ACCESS_TOKEN_EXP_MINUTES=60
REFRESH_TOKEN_EXP_DAYS=7

# Request limiting and cache retention.
RATE_LIMIT_PER_MINUTE=30
CHAT_CACHE_TTL_SECONDS=300
UPLOAD_CACHE_TTL_SECONDS=3600
